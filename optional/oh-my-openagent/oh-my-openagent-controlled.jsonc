{
  // Optional project config for the official oh-my-openagent runtime.
  // Verified against upstream commit fb74d777 (2026-07-11). Copy this file to
  // `.opencode/oh-my-openagent.jsonc`; do not nest it under an
  // `oh-my-openagent` key.
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 6,
    "max_wall_clock_minutes": 120
  },

  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 30,
    "default_strategy": "continue"
  },

  // Keep upstream continuation and safety hooks enabled. Hooks are disabled
  // only by listing them in `disabled_hooks`.
  "disabled_hooks": [],
  "telemetry": false
}
