{
  // Reference config consumed by research-learn-loop.plugin.ts if you wire it up.
  "enabled": true,
  "cooldownMs": 10000,
  "maxStagnantRounds": 3,
  "maxFailures": 5,
  "searchMemoryFirst": true,
  "requireRollbackPlan": true,
  "recordSuccess": true,
  "recordFailure": true,
  "skills": [
    "experience-ledger",
    "research-discovery",
    "mcp-skill-scout",
    "community-research",
    "solution-trial-loop",
    "self-improvement"
  ],
  "memorySource": "SQLite (.opencode/memory/memory.db)",
  "memoryTools": [
    "memory_search",
    "memory_add",
    "memory_read",
    "memory_list"
  ]
}
