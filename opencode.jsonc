{
  "$schema": "https://opencode.ai/config.json",

  // Default agent: orchestrator (odin). Use --agent build for build/execution mode.
  "default_agent": "odin",
  // Model inherits from global config (~/.config/opencode/opencode.jsonc).
  // Uncomment and set to override:
  // "model": "openai/gpt-5.5",
  "autoupdate": true,

  // Safe default permissions. Increase only inside trusted project sandboxes.
  "permission": {
    "edit": "ask",
    "webfetch": "ask",
    "bash": {
      // 預設全部 allow，僅封鎖危險操作（與全域設定一致）
      "*": "allow",
      "del /s*": "deny",
      "git clean*": "deny",
      "git push*": "ask",
      "git reset --hard*": "deny",
      "pip install*": "ask",
      "rm -r *": "ask",
      "rm -rf *": "deny",
      "rmdir /s*": "deny",
      "Remove-Item * -Recurse*": "deny"
    }
  },

  // OpenCode reads markdown agents from .opencode/agent/*.md.
  // Keep global default conservative; individual agents define their own boundaries.
  "agent": {
    "odin": {
      "permission": {
        "edit": "ask",
        "webfetch": "ask"
      }
    },
    "hephaestus": {
      "permission": {
        "edit": "ask",
        "webfetch": "ask"
      }
    },
    "merlin": {
      "permission": {
        "edit": "deny",
        "webfetch": "ask"
      }
    },
    "explore": {
      "permission": {
        "edit": "deny",
        "webfetch": "deny"
      }
    },
    "librarian": {
      "permission": {
        "edit": "deny",
        "webfetch": "ask"
      }
    },
    "multimodal-looker": {
      "permission": {
        "edit": "deny",
        "webfetch": "deny"
      }
    }
  },

  // Optional MCP servers. Add read-only docs/search MCPs here when available.
  // Use `opencode mcp add` for interactive setup. Keep mutating MCPs gated.
  "mcp": {},


  // Custom tools are loaded from .opencode/tools/.
  // This package provides memory_add, memory_search, memory_read, memory_list in .opencode/tools/memory.ts.
  // Local plugins are auto-loaded from .opencode/plugins/; keep plugin empty unless adding npm plugins.

  // Optional plugins. Local plugin files are placed in .opencode/plugins/.
  // Both plugins are auto-enabled by the install script; remove entries to disable.
  "plugin": [
    ".opencode/plugins/memory-lifecycle.plugin.ts",
    ".opencode/plugins/research-learn-loop.plugin.ts"
  ]

}
