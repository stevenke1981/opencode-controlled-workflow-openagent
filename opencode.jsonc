{
  "$schema": "https://opencode.ai/config.json",

  // Default agent: orchestrator (odin). Use --agent build for build/execution mode.
  "default_agent": "odin",
  // Model inherits from global config (~/.config/opencode/opencode.jsonc).
  // Uncomment and set to override:
  // "model": "openai/gpt-5.5",
  "autoupdate": true,

  // Safe default permissions. Increase only inside trusted project sandboxes.
  "permission": {
    "edit": "ask",
    "webfetch": "ask",
    "bash": {
      // 預設全部 allow，僅封鎖危險操作（與全域設定一致）
      "*": "allow",
      "del /s*": "deny",
      "git clean*": "deny",
      "git push*": "ask",
      "git reset --hard*": "deny",
      "pip install*": "ask",
      "rm -r *": "ask",
      "rm -rf *": "deny",
      "rmdir /s*": "deny",
      "Remove-Item * -Recurse*": "deny"
    }
  },

  // OpenCode reads markdown agents from .opencode/agent/*.md.
  // Keep global default conservative; individual agents define their own boundaries.
  "agent": {
    "odin": {
      "permission": {
        "edit": "ask",
        "webfetch": "ask"
      }
    },
    "hephaestus": {
      "permission": {
        "edit": "ask",
        "webfetch": "ask"
      }
    },
    "merlin": {
      "permission": {
        "edit": "deny",
        "webfetch": "ask"
      }
    },
    "explore": {
      // A global config may disable OpenCode's built-in explore agent. This
      // project provides its own read-only Explore definition, so re-enable it.
      "disable": false,
      "permission": {
        "edit": "deny",
        "webfetch": "deny"
      }
    },
    "librarian": {
      "permission": {
        "edit": "deny",
        "webfetch": "ask"
      }
    },
    "multimodal-looker": {
      "permission": {
        "edit": "deny",
        "webfetch": "deny"
      }
    }
  },

  // Optional MCP servers. Hermes-created fragments live under
  // .opencode/evolution/mcp and are merged by hermes-self-evolution.plugin.ts.
  // New fragments are disabled until explicitly reviewed and enabled.
  "mcp": {},


  // Custom tools and local plugins are auto-discovered from .opencode/tools
  // and .opencode/plugins. Do not repeat their paths here: explicit entries
  // plus auto-discovery execute the same plugin more than once.
  "plugin": []

}
